// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User{
  id String @id @default(uuid())
  email String @unique
  password String?
  name String
  provider String
  googleId String?
  createdAt DateTime @default(now())
  accounts Account[]
  alerts Alert[]
}

model Account{
  id String @id @default(uuid())
  name String
  balance Float
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  orders Order[]
  positions Position[]
  marginUsed Float @default(0)
  auditLogs AuditLog[]
  netPnl Float? @default(0)
  charges Float? @default(0)
  journals  Journal[]
  feedback AiFeedback[]
}

model Order{
  id String @id @default(uuid())
  accountId String
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  symbol String
  direction Direction
  status OrderStatus @default(PENDING)
  quantity Int
  type orderType
  price Float
  filledQty Int @default(0)
  filledPrice Float?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cancelledAt DateTime?
  trades Trade[]
  leverage Int @default(1)
   slPrice     Float?    // for bracket orders
  slQty       Float?
  tpPrice     Float?
  tpQty       Float?
  isBracket   Boolean   @default(false)
 
}


model Position{
  id String @id @default(uuid())
  accountId String
  account Account @relation(fields: [accountId], references: [id], onDelete:Cascade)
  symbol String
  direction Direction
  quantity Int
  avgEntryPrice Float
  realizedPnl Float @default(0)
  isOpen Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leverage Int @default(1)
  marginUsed Float @default(0)
  slPrice     Float?    // stop loss price
  tpPrice     Float?    // take profit price
  slHit       Boolean   @default(false)  // already triggered?
  tpHit       Boolean   @default(false)
   closedAt DateTime?
}
model Trade{
  id String @id @default(uuid())
  orderId String?
  order Order? @relation(fields: [orderId], references: [id] , onDelete: Cascade)
  accountId String
  symbol String
  direction Direction
  quantity Int
  price Float
  realizedPnl Float @default(0)
  createdAt DateTime @default(now())
  trigger   String?   
  charges  Float?

}

model AuditLog {
  id        String      @id @default(uuid())
  accountId String
  account   Account     @relation(fields: [accountId], references: [id],onDelete: Cascade)
  type      AuditType
  message   String
  meta      Json?       // any extra data — prices, quantities etc
  createdAt DateTime    @default(now())
}


model Alert{
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete:Cascade)

  name String
  price Float
  status AlertStatus
  type AlertType
  symbol String
}
model Journal {
  id         String   @id @default(cuid())

  accountId  String
  account    Account  @relation(fields: [accountId], references: [id])

  script String
  date       DateTime

  entryTime  DateTime
  exitTime   DateTime?

  pnl        Float?

  entryReason String
  exitReason  String?

  notes      Note[]

  quantity Int

  createdAt DateTime @default(now())
}

model Note {
  id         String   @id @default(cuid())

  journalId  String
  journal    Journal  @relation(fields: [journalId], references: [id])

  content    String

  createdAt  DateTime @default(now())
}

model AiFeedback {
  id            String   @id @default(cuid())

  accountId     String
  account       Account  @relation(fields: [accountId], references: [id])

  content       Json     // ✅ structured AI output (IMPORTANT CHANGE)

  summary       String?

  biggestWin    Float?
  biggestLoss   Float?

  totalJournals Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([accountId])
}
enum AlertStatus{
  PENDING
  TRIGGERED
}

enum AlertType{
  LTE
  GTE
  ET
}

enum AuditType {
  ORDER_PLACED
  ORDER_FILLED
  ORDER_CANCELLED
  ORDER_EXPIRED
  POSITION_OPENED
  POSITION_CLOSED
  POSITION_FLIPPED
  MARGIN_CALL
  LIQUIDATION
}

enum Direction{
  LONG
  SHORT
}

enum orderType{
  MARKET
  LIMIT
}
enum OrderStatus{
  PENDING
  FILLED
  PARTIALLY_FILLED
  CANCELLED
  EXPIRED
}